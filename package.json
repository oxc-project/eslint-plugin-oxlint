{
  "name": "eslint-plugin-oxlint",
  "version": "1.57.0",
  "description": "Turn off all rules already supported by oxlint",
  "keywords": [
    "eslint",
    "oxc",
    "oxlint",
    "rules"
  ],
  "homepage": "https://github.com/oxc-project/eslint-plugin-oxlint",
  "license": "MIT",
  "author": "Dunqing <dengqing0821@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git@github.com:oxc-project/eslint-plugin-oxlint.git"
  },
  "files": [
    "dist",
    "src",
    "!**/*.snap",
    "!**/*.spec.ts"
  ],
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "default": "./dist/index.mjs"
    },
    "./rules-by-category": {
      "types": "./dist/generated/rules-by-category.d.ts",
      "import": "./dist/generated/rules-by-category.mjs",
      "require": "./dist/generated/rules-by-category.cjs",
      "default": "./dist/generated/rules-by-category.mjs"
    },
    "./rules-by-scope": {
      "types": "./dist/generated/rules-by-scope.d.ts",
      "import": "./dist/generated/rules-by-scope.mjs",
      "require": "./dist/generated/rules-by-scope.cjs",
      "default": "./dist/generated/rules-by-scope.mjs"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "prepare": "husky",
    "generate": "node --import @oxc-node/core/register ./scripts/generate-vitest-rules.ts && node --import @oxc-node/core/register ./scripts/generate.ts && pnpm format",
    "build": "vite build",
    "lint": "npx oxlint",
    "format": "npx oxfmt",
    "test": "vitest --reporter=verbose"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@oxc-node/core": "^0.0.35",
    "@types/node": "^25.5.0",
    "@types/shelljs": "^0.10.0",
    "@vitest/coverage-v8": "^4.1.0",
    "dedent": "^1.7.2",
    "eslint": "^10.0.3",
    "eslint-plugin-unicorn": "^63.0.0",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "lint-staged": "^16.4.0",
    "memfs": "^4.56.11",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.17.0",
    "scule": "^1.3.0",
    "shelljs": "^0.10.0",
    "typescript-eslint": "^8.57.1",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^4.5.4",
    "vitest": "^4.1.0"
  },
  "peerDependencies": {
    "oxlint": "~1.57.0"
  },
  "lint-staged": {
    "*.{js,cjs,ts}": "pnpm run lint",
    "*": "oxfmt ."
  },
  "volta": {
    "node": "20.18.0"
  },
  "packageManager": "pnpm@10.32.1"
}
